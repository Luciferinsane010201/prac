   "source": [
    "# Cell 2: Connect to Server\n",
    "proxy = xmlrpc.client.ServerProxy(\"http://localhost:8000/\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "e00fed65-734a-4ba3-8e0d-dd64f5f4cd0c",
