     "text": [
      "Factorial of 5 is: 120\n"
     ]
    }
   ],
   "source": [
    "# Cell 3: Call Remote Function\n",
    "num = 5\n",
    "result = proxy.factorial(num)\n",
    "\n",
    "print(f\"Factorial of {num} is:\", result)"
   ]
